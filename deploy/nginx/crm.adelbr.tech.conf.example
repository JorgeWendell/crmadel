# Exemplo para Nginx no servidor (host).
# Copie para: /etc/nginx/sites-available/crm.adelbr.tech
# Depois: ln -s /etc/nginx/sites-available/crm.adelbr.tech /etc/nginx/sites-enabled/
#
# Certificado Let's Encrypt:
#   certbot --nginx -d crm.adelbr.tech
#
# O app Docker deve estar em 127.0.0.1:3000 (porta APP_PORT do .env)

server {
    listen 80;
    server_name crm.adelbr.tech;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

# Após certbot, ele adiciona automaticamente o bloco listen 443 ssl.
