# Copie este arquivo para .env antes de subir os containers:
#   cp .env.docker.example .env
#
# Em produção, troque as senhas e use o domínio real nas URLs.

# PostgreSQL (container: db)
POSTGRES_USER=adelcrm
POSTGRES_PASSWORD=troque_por_uma_senha_forte
POSTGRES_DB=adelcrm

# App (container: app)
APP_PORT=3000
BETTER_AUTH_SECRET=troque_por_um_secret_longo_e_aleatorio
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Produção (exemplo):
# BETTER_AUTH_URL=https://crm.adelbr.tech
# NEXT_PUBLIC_BASE_URL=https://crm.adelbr.tech

# A DATABASE_URL é montada automaticamente pelo docker-compose:
# postgresql://adelcrm:SENHA@db:5432/adelcrm
# O hostname "db" é o nome do serviço Postgres na rede interna do Docker.
